<UserControl x:Class="BookLibrary.UI.Controls.BookView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BookLibrary.UI.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1200">
    <Grid HorizontalAlignment="Center" Width="1000" Height="336" VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width=".15*" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="3*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <Label Content="Name:" Grid.Row="0" Grid.Column="0" Margin="0,0,0,3" Foreground="#FFFFD200" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
        
        <Label Content="Year:" Grid.Column="0" Foreground="#FFFFD200" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Grid.Row="1"/>
        <TextBox x:Name="tbBookName" Style="{StaticResource MyTextBox}" Grid.Column="1" Margin="40,40,40,47" Text="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=BookName}" TextWrapping="Wrap" AcceptsReturn="True" AcceptsTab="True" SpellCheck.IsEnabled="True"  HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
        </TextBox>
        <DatePicker x:Name="dpBookDate" SelectedDate="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=BookYear}" Grid.Column="1" Margin="40,0,252,0" Grid.Row="1" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" BorderBrush="{x:Null}">
            <DatePicker.Resources>
                <Style TargetType="DatePickerTextBox">
                    <Setter Property="Background">
                        <Setter.Value>
                            <SolidColorBrush Color="White" Opacity="0"/>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DatePicker.Resources>
            <DatePicker.Foreground>
                <SolidColorBrush Color="#FFFFD200"/>
            </DatePicker.Foreground>
        </DatePicker>
        <StackPanel Grid.Column="2" Grid.Row="0" Grid.RowSpan="2">
            <DockPanel Height="35" LastChildFill="True">
                <Button x:Name="btnAddAuthor" Style="{StaticResource ActionButton}" Content="Add" Height="23" Width="32" DockPanel.Dock="Right" Margin="5,5,5,5" Click="btnAddAuthor_Click"/>
                <Label Content="Authors:" Foreground="#FFFFD200" FontSize="18" Width="78"/>
            </DockPanel>
            <StackPanel x:Name="spAuthors">
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
